# GROQ API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration (optional - defaults provided)
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Alternative vision model: meta-llama/llama-4-maverick-17b-128e-instruct
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Performance Note:
# - Vision model uses optimized prompts for 2-3x faster response
# - Temperature=0.3 for faster, more consistent decisions
# - Compact JSON responses reduce processing time

# Server Configuration (optional)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# SERVER_DEBUG=false
